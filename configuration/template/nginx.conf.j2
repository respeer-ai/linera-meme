upstream {{ service.mutation_endpoint }} {
{% for value in service.mutation_servers %}
    server {{ value }};
{% endfor %}
}

{% if service.query_servers %}
upstream {{ service.query_endpoint }} {
{% for value in service.query_servers %}
    server {{ value }};
{% endfor %}
}
{% endif %}

map $http_upgrade $connection_upgrade {
    default upgrade;
    ""      close;
}

server {
    listen 80;
    server_name {{ service.sub_domain }}{{ service.domain }} graphiql.{{ service.domain }};

    add_header Access-Control-Allow-Origin  '*';
    add_header Access-Control-Allow-Methods 'GET, POST, OPTIONS';
    add_header Access-Control-Allow-Headers 'DNT,X-Mx-ReqToken,Keep-Alive,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Authorization';
    add_header Cross-Origin-Resource-Policy cross-origin;

    if ($request_method = OPTIONS) {
        return 204;
    }

    client_max_body_size 20m;

{% if service.query_servers %}
    location /api/{{ service.api_endpoint }}/query {
        proxy_pass http://{{ service.query_endpoint }}/;

        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_hide_header 'Access-Control-Allow-Origin';
    }

    location /api/{{ service.api_endpoint }}/query/ {
        proxy_pass http://{{ service.query_endpoint }}/;

        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_hide_header 'Access-Control-Allow-Origin';
    }
{% endif %}

    location /api/{{ service.api_endpoint }} {
        proxy_pass http://{{ service.mutation_endpoint }}/;

        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_hide_header 'Access-Control-Allow-Origin';
    }

    location /api/{{ service.api_endpoint }}/ {
        proxy_pass http://{{ service.mutation_endpoint }}/;

        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_hide_header 'Access-Control-Allow-Origin';
    }

    location / {
        proxy_pass http://{{ service.mutation_endpoint }}/;
    }

    location /api/{{ service.api_endpoint }}/ws {
        proxy_pass http://{{ service.mutation_endpoint }}/ws;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        keepalive_timeout 90;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
